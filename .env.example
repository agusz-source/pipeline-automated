# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Apify ────────────────────────────────────────────────────
# Token from https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_...
# Google Maps Scraper actor (default: compass/crawler-google-places)
APIFY_ACTOR_ID=compass/crawler-google-places

# ── GitHub (for Vercel projects if needed) ───────────────────
GITHUB_USERNAME=

# ── WhatsApp Node Bridge ──────────────────────────────────────
# Port where the Node.js bridge listens for Python commands
WA_BRIDGE_PORT=3001
# Port where Python listens for Node.js message events
WA_EVENTS_PORT=3002
